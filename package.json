{
  "name": "kai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "worker:typecheck": "tsc -p tsconfig.worker.json --noEmit",
    "check": "npm run build && npm run worker:typecheck",
    "lint": "eslint .",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "worker:dev": "wrangler dev --config wrangler.worker.toml",
    "worker:deploy": "wrangler deploy --config wrangler.worker.toml",
    "worker:deploy:staging": "wrangler deploy --config wrangler.worker.toml --env staging"
  },
  "dependencies": {
    "@clerk/backend": "^2.33.3",
    "@clerk/clerk-react": "^5.24.1",
    "@hono/clerk-auth": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "hono": "^4.7.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@eslint/js": "^9.21.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.2",
    "vitest": "^3.0.8",
    "wrangler": "^4.3.0"
  }
}
